# PostgreSQL (docker-compose)
POSTGRES_DB=craft_map
POSTGRES_USER=craft
POSTGRES_PASSWORD=change-me-strong-password

# Auth.js — сгенерировать: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32
# Публичный URL сайта (для Auth.js за nginx)
AUTH_URL=https://example.ru

# Первичный администратор (создаётся seed-скриптом, если пользователей ещё нет)
ADMIN_EMAIL=admin@example.ru
ADMIN_PASSWORD=change-me-admin-password
