# PostgreSQL (docker-compose)
POSTGRES_DB=craft_map
POSTGRES_USER=craft
POSTGRES_PASSWORD=change-me-strong-password

# Auth.js — сгенерировать: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32
# Публичный URL сайта (для Auth.js за nginx)
AUTH_URL=https://example.ru

# Первичный администратор (создаётся seed-скриптом, если пользователей ещё нет)
ADMIN_EMAIL=admin@example.ru
ADMIN_PASSWORD=change-me-admin-password

# Yandex SpeechKit TTS — только серверные переменные, без префикса NEXT_PUBLIC_.
# ID нужен лишь для учёта ключа и не отправляется в SpeechKit API.
YANDEX_SPEECHKIT_API_KEY_ID=
YANDEX_SPEECHKIT_API_KEY=

# Необязательно: параметры атомарного backup.sh
# BACKUP_DIR=/var/backups/craft-map
# KEEP_DAYS=14
# BACKUP_MAX_AGE_SECONDS=600
# Внешнее хранилище opt-in (SSH/rsync):
# BACKUP_REMOTE=backup@example.ru:/srv/backups/craft-map
# UPLOAD_CLEANUP_GRACE_HOURS=24

# Необязательно: проверенная страница фонда/оплаты. Без URL кнопка не показывается.
# NEXT_PUBLIC_DONATION_URL=https://example.ru/donate
